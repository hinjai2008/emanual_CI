{"type":"data","nodes":[{"type":"data","data":[null],"uses":{}},{"type":"data","data":[{"entryData":1},{"id":2,"refId":3,"full_name":4,"GCRS_name":13,"label_name":19,"synonyms":26,"container":32,"test_handling":41,"turn_around_time":48,"lab_and_category":55,"indication":65,"form":128},929,96583682,{"time":5,"blocks":6,"version":12},1776044652262,[7],{"id":8,"type":9,"data":10},"l_O7NC8Dq2","paragraph",{"text":11},"Anti-Cardiolipin Antibody, IgG","2.31.0-rc.7",{"time":14,"blocks":15,"version":12},1776044654200,[16],{"id":17,"type":9,"data":18},"bvz8sljKtf",{"text":11},{"time":20,"blocks":21,"version":12},1776044656927,[22],{"id":23,"type":9,"data":24},"wgOIkppgqM",{"text":25},"ACL,IgG(PMH)",{"blocks":27},[28],{"type":29,"data":30},"synonyms",{"synonymList":31},[],{"time":33,"blocks":34,"version":12},1776044706807,[35],{"id":36,"type":37,"data":38},"R7hgxgt9zA","container",{"text":39,"imageSrc":40},"##CLOT_BLOOD_TUBE##","/clot_blood_x1.webp",{"time":42,"blocks":43,"version":12},1776044772550,[44],{"id":45,"type":9,"data":46},"_8vIZ_gtA_",{"text":47},"No aliquot and keep at 4°C if arrive at PMH within 48 hours; otherwise aliquot and keep at -20°C",{"time":49,"blocks":50,"version":12},1776044792559,[51],{"id":52,"type":9,"data":53},"EJtqZtx5NJ",{"text":54},"2 weeks",{"time":56,"blocks":57,"version":12},1776044804038,[58],{"id":59,"type":60,"data":61},"hW6w2mDrzp","lab_and_category",{"labName":62,"categoryCode":63,"categoryName":64},"PMH Haematology Lab","HAEM","Haematology",{"time":66,"blocks":67,"version":12},1776044852583,[68,72,76,80,84,88,92,96,100,104,108,112,116,120,124],{"id":69,"type":9,"data":70},"PdAL5OW2jT",{"text":71},"Indication for Test:",{"id":73,"type":9,"data":74},"uJ_rkMQ0cm",{"text":75},"Differential diagnosis of recurrent thrombosis, lupus-like syndromes, false positive VDRL or Rapid Plasma Reagin Test(RPR), recurrent fetal loss.",{"id":77,"type":9,"data":78},"nsLLAsnvV4",{"text":79},"Limitation for Test:",{"id":81,"type":9,"data":82},"PmHnVIohF9",{"text":83},"1. Rheumatoid factor may interfere with this assay.",{"id":85,"type":9,"data":86},"wdk-SF_Xy_",{"text":87},"2. ACL occur transiently in a variety of infectious diseases.",{"id":89,"type":9,"data":90},"nwXTiPMc8U",{"text":91},"3. Confirmed active or seropositive syphilis patients can have elevated ACL levels.",{"id":93,"type":9,"data":94},"4IsTTgtE4k",{"text":95},"4. ACL have also been associated with neurological syndromes such as transient ischemic attacks and migraine. In contrast, in patients with antiphospholipid syndrome, ACL usually persist for longer periods and may even precede the onset of clinical symptoms.",{"id":97,"type":9,"data":98},"6AclDdvjHL",{"text":99},"Additional Information:",{"id":101,"type":9,"data":102},"10sPD8fm82",{"text":103},"1. Only test for IgG ACL will be performed.",{"id":105,"type":9,"data":106},"9i9JYUVTXB",{"text":107},"2. Anti-cardiolipin antibodies are autoantibodies directed against negatively charged phospholipids. These",{"id":109,"type":9,"data":110},"4-yNCNB-nf",{"text":111},"antibodies have been detected in the sera of patients with SLE, other autoimmune rheumatic diseases,",{"id":113,"type":9,"data":114},"4PwKXYS-vz",{"text":115},"and primary antiphospholipid syndrome.",{"id":117,"type":9,"data":118},"HmaqQXwf5f",{"text":119},"3. The presence of ACL is associated with thromboembolic complications and is the hallmark of",{"id":121,"type":9,"data":122},"pSLfz0Y_M4",{"text":123},"antiphospholipid syndrome.",{"id":125,"type":9,"data":126},"Mwv1kKrI8t",{"text":127},"4. In published studies of SLE, the incidence of ACL is 30-50%.",{"time":129,"blocks":130,"version":12},1776045065709,[131],{"id":132,"type":133,"data":134},"LN3Dk5azEf","form",{"form":135},{"form_id":136,"form_ref_id":136,"form_code":136,"form_name":136,"form_link":136,"form_external_link":136,"formRequestOnly":137,"specialTier":137},"",false],"uses":{"params":["id"]}}]}
